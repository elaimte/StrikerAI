PORT=3000
HOST=0.0.0.0
COMPANY_NAME=Striker AI

# Fill these when connecting live Bolna call trigger.
BOLNA_AGENT_ID=
BOLNA_API_KEY=
BOLNA_BASE_URL=https://api.bolna.ai
BOLNA_CALL_ENDPOINT_PATH=/call

# Optional: use dedicated outbound number on Bolna
BOLNA_FROM_PHONE_NUMBER=

# Optional: set full URL if you want to override base+path
# BOLNA_CALL_ENDPOINT_URL=https://api.bolna.ai/call
